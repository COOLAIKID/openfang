# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (auth + database) ──────────────────────────────────────────────
# Create a project at https://supabase.com, then run the migration in
# supabase/migrations/0001_init.sql. Enable the Google provider under
# Authentication → Providers for Google login.
# Leave blank to run the full product in demo mode (no auth, no persistence).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI layer (OpenRouter) ───────────────────────────────────────────────────
# One key routes to Claude, Gemini, and DeepSeek with automatic fallback.
# Leave blank to use the deterministic demo engine for all agent workflows.
OPENROUTER_API_KEY=

# Optional model overrides (defaults shown)
OPENROUTER_MODEL_STRATEGY=anthropic/claude-sonnet-4
OPENROUTER_MODEL_EXTRACTION=google/gemini-2.5-flash
OPENROUTER_MODEL_GENERATION=deepseek/deepseek-chat-v3-0324
