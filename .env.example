# AutoEarn — environment variables
# Copy this file to .env and fill in your keys.
# docker compose and main.py both read .env automatically.

# ── AI providers (set at least one) ─────────────────────────────────────────
GROQ_API_KEY=
GOOGLE_API_KEY=
HUGGINGFACE_API_TOKEN=
MISTRAL_API_KEY=

# ── Publishing integrations (optional) ──────────────────────────────────────
WP_URL=https://yourblog.com
WP_USER=admin
WP_APP_PASSWORD=

MEDIUM_TOKEN=

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=AutoEarn/1.0

# ── Dashboard server ─────────────────────────────────────────────────────────
# Access via http://localhost:4200 (or your LAN IP for phone access)
SERVER_HOST=0.0.0.0
SERVER_PORT=4200
