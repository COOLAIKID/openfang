{
  "name": "AutoEarn",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "onCreateCommand": "pip install -q -r /workspaces/openfang/autoearn/requirements-cloud.txt",

  "postStartCommand": "python3 /workspaces/openfang/.devcontainer/start.py",

  "forwardPorts": [4200],
  "portsAttributes": {
    "4200": {
      "label": "AutoEarn Dashboard",
      "onAutoForward": "notify",
      "visibility": "public",
      "protocol": "http"
    }
  },

  "remoteEnv": {
    "HOST": "0.0.0.0",
    "PORT": "4200"
  }
}
